{
  "name": "pagx-player",
  "version": "0.1.0",
  "description": "PAGX Player - Shared player UI (canvas gestures, playback bar, toolbar, source editor) reused by pagx-playground and pagx-preview.",
  "type": "module",
  "main": "lib/pagx-player.esm.js",
  "module": "lib/pagx-player.esm.js",
  "types": "lib/pagx-player.d.ts",
  "exports": {
    ".": {
      "types": "./lib/pagx-player.d.ts",
      "import": "./lib/pagx-player.esm.js",
      "default": "./lib/pagx-player.esm.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "clean": "rimraf lib",
    "build": "rollup -c ./scripts/rollup.config.mjs",
    "build:release": "BUILD_MODE=release rollup -c ./scripts/rollup.config.mjs"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "~28.0.3",
    "@rollup/plugin-node-resolve": "~16.0.1",
    "esbuild": "~0.25.0",
    "rimraf": "~5.0.10",
    "rollup": "~4.18.0",
    "rollup-plugin-esbuild": "~6.1.1",
    "rollup-plugin-dts": "~6.1.1",
    "typescript": "~5.0.3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3"
  },
  "license": "Apache-2.0",
  "author": "Tencent"
}
