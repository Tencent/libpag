{
  "name": "pagx-playground",
  "version": "1.0.0",
  "specVersion": "1.0",
  "specStableVersion": "",
  "description": "PAGX Playground",
  "type": "module",
  "scripts": {
    "clean": "rimraf public/wasm-mt/index.js public/wasm-mt/index.js.map public/fonts .*.md5",
    "prebuild": "node script/prebuild.js",
    "build": "npm run prebuild && rollup -c ./script/rollup.js",
    "build:release": "node script/prebuild.js --release && BUILD_MODE=release rollup -c ./script/rollup.js",
    "publish": "node script/publish.js",
    "server": "node public/server.js"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "~5.1.1",
    "@rollup/plugin-commonjs": "~28.0.3",
    "@rollup/plugin-json": "~6.1.0",
    "@rollup/plugin-node-resolve": "~16.0.1",
    "@types/emscripten": "~1.39.6",
    "esbuild": "~0.15.14",
    "rimraf": "~5.0.10",
    "rollup": "~2.79.1",
    "rollup-plugin-esbuild": "~4.10.3",
    "rollup-plugin-terser": "~7.0.2",
    "tslib": "~2.4.1",
    "typescript": "~5.0.3"
  },
  "dependencies": {
    "express": "^4.21.1",
    "highlight.js": "^11.9.0",
    "marked": "^15.0.0",
    "marked-gfm-heading-id": "^4.1.0",
    "marked-highlight": "^2.2.0"
  },
  "license": "Apache-2.0",
  "author": "Tencent"
}
