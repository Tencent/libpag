{
  "compilerOptions": {
    "target": "ES2020",
    "declaration": true,
    "declarationDir": "./types",
    "emitDeclarationOnly": true,
    "removeComments": false,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@tgfx/*": ["../../third_party/tgfx/web/src/*"],
      "pagx-glue": ["./wasm-mt/pagx-viewer"]
    }
  },
  "include": ["src/ts/pagx.ts"]
}
