#!/usr/bin/env bash
# html2pagx — one-shot pipeline for converting a JS/React-driven HTML page into a
# rendered PAGX. Wraps four steps:
#
#   1. snapshot.js     <input>.html        → <input>.subset.html
#   2. pagx import     <input>.subset.html → <input>.pagx
#   3. pagx resolve    <input>.pagx
#   4. pagx render     <input>.pagx        → <input>.png
#
# Usage:
#   html2pagx <input.html | http(s)://url> [options]
#
# Options (any unknown flag is forwarded to snapshot.js):
#   -o, --output-dir <dir>     Write outputs to <dir> (default: same dir as input)
#   --output-name <name>       Base name for outputs (required when input is a URL)
#   --pagx-bin <path>          Path to the pagx CLI (default: $PAGX_BIN or
#                              ../../cmake-build-debug/pagx relative to this script)
#   --scale <N>                Render scale factor (default: 1)
#   --no-render                Stop after pagx resolve; do not produce PNG
#   --no-resolve               Stop after pagx import; do not run resolve/render
#   --no-infer-flex            Disable AbsoluteToFlexInference (default: on)
#   --no-subset-html           Do not write <input>.subset.html (use a temp file
#                              that is removed after import); default keeps it
#   --no-inline-icon-fonts     Forwarded to snapshot.js: disable webfont-glyph
#                              → inline SVG conversion (default: enabled)
#   --cookie <name=value>      Forwarded to snapshot.js (URL inputs only; repeatable)
#   --header <Key: Value>      Forwarded to snapshot.js (URL inputs only; repeatable)
#   --browser-engine <name>    Headless browser driver: 'puppeteer' (default)
#                              or 'playwright'. Forwarded to snapshot.js.
#                              Honours $HTML_SNAPSHOT_BROWSER.
#   -h, --help                 Show this help

set -eu
set -o pipefail

#--------------------------------------------------------------------------------------------------
# Locate this script's directory so we can call snapshot.js and the bundled pagx default.
#--------------------------------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

DEFAULT_PAGX_BIN="${PAGX_BIN:-$REPO_ROOT/cmake-build-debug/pagx}"

print_usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

# Run an external command and abort the script with a uniform error message
# on non-zero exit. Use this for the snapshot/resolve/render steps where a
# failure should terminate html2pagx with `html2pagx: <label> failed`. The
# `pagx import` step is excluded — it pipes through `grep` to filter known
# warnings, so its exit code is intentionally swallowed and a `[[ ! -f ]]`
# check verifies success after the pipe.
run_step() {
  local label="$1"
  shift
  if ! "$@"; then
    echo "html2pagx: ${label} failed" >&2
    exit 1
  fi
}

#--------------------------------------------------------------------------------------------------
# Arg parsing
#--------------------------------------------------------------------------------------------------
INPUT=""
OUTPUT_DIR=""
OUTPUT_NAME=""
PAGX_BIN="$DEFAULT_PAGX_BIN"
SCALE="1"
DO_RESOLVE=1
DO_RENDER=1
INFER_FLEX=1
KEEP_SUBSET_HTML=1
SNAPSHOT_EXTRA_ARGS=()
# Browser engine: defaults to puppeteer; --browser-engine wins over the env
# var which wins over this default. Captured separately from
# SNAPSHOT_EXTRA_ARGS so the preflight check (below) can look at it.
BROWSER_ENGINE="${HTML_SNAPSHOT_BROWSER:-puppeteer}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      print_usage
      exit 0
      ;;
    -o|--output-dir)
      OUTPUT_DIR="$2"
      shift 2
      ;;
    --output-name)
      OUTPUT_NAME="$2"
      shift 2
      ;;
    --pagx-bin)
      PAGX_BIN="$2"
      shift 2
      ;;
    --scale)
      SCALE="$2"
      shift 2
      ;;
    --no-render)
      DO_RENDER=0
      shift
      ;;
    --no-resolve)
      DO_RESOLVE=0
      DO_RENDER=0
      shift
      ;;
    --no-infer-flex)
      INFER_FLEX=0
      shift
      ;;
    --no-subset-html)
      KEEP_SUBSET_HTML=0
      shift
      ;;
    --viewport-width|--viewport-height|--wait-ms|--selector|--cookie|--header)
      SNAPSHOT_EXTRA_ARGS+=("$1" "$2")
      shift 2
      ;;
    --browser-engine)
      BROWSER_ENGINE="$2"
      shift 2
      ;;
    --no-inline-icon-fonts)
      SNAPSHOT_EXTRA_ARGS+=("$1")
      shift
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        SNAPSHOT_EXTRA_ARGS+=("$1")
        shift
      done
      ;;
    -*)
      echo "html2pagx: unknown option '$1'" >&2
      echo "Run with --help for usage." >&2
      exit 2
      ;;
    *)
      if [[ -z "$INPUT" ]]; then
        INPUT="$1"
      else
        echo "html2pagx: unexpected positional argument '$1'" >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "$INPUT" ]]; then
  echo "html2pagx: missing input HTML file" >&2
  echo "Run with --help for usage." >&2
  exit 2
fi

#--------------------------------------------------------------------------------------------------
# Resolve absolute paths
#--------------------------------------------------------------------------------------------------
IS_URL=0
if [[ "$INPUT" =~ ^https?:// ]]; then
  IS_URL=1
fi

if [[ "$IS_URL" -eq 1 ]]; then
  if [[ -z "$OUTPUT_NAME" ]]; then
    echo "html2pagx: --output-name <name> is required when input is a URL" >&2
    exit 2
  fi
  INPUT_ABS="$INPUT"
  INPUT_BASE="$OUTPUT_NAME"
  OUT_DIR="${OUTPUT_DIR:-$(pwd)}"
  mkdir -p "$OUT_DIR"
  OUT_DIR="$(cd "$OUT_DIR" && pwd)"
else
  if [[ ! -f "$INPUT" ]]; then
    echo "html2pagx: input not found: $INPUT" >&2
    exit 1
  fi

  INPUT_ABS="$(cd "$(dirname "$INPUT")" && pwd)/$(basename "$INPUT")"
  INPUT_DIR="$(dirname "$INPUT_ABS")"
  if [[ -n "$OUTPUT_NAME" ]]; then
    INPUT_BASE="$OUTPUT_NAME"
  else
    INPUT_BASE="$(basename "$INPUT_ABS" .html)"
    INPUT_BASE="${INPUT_BASE%.htm}"
  fi

  OUT_DIR="${OUTPUT_DIR:-$INPUT_DIR}"
  if [[ -n "$OUTPUT_DIR" ]]; then
    mkdir -p "$OUT_DIR"
    OUT_DIR="$(cd "$OUT_DIR" && pwd)"
  fi
fi

SUBSET_HTML="$OUT_DIR/${INPUT_BASE}.subset.html"
PAGX_FILE="$OUT_DIR/${INPUT_BASE}.pagx"
PNG_FILE="$OUT_DIR/${INPUT_BASE}.png"

# When the user opts out of keeping the subset HTML on disk, redirect it into a
# self-cleaning temp directory so the pagx import step still has a file to read.
if [[ "$KEEP_SUBSET_HTML" -ne 1 ]]; then
  TMP_DIR="$(mktemp -d -t html2pagx)"
  trap 'rm -rf "$TMP_DIR"' EXIT
  SUBSET_HTML="$TMP_DIR/${INPUT_BASE}.subset.html"
fi

#--------------------------------------------------------------------------------------------------
# Pre-flight
#--------------------------------------------------------------------------------------------------
# Validate the selected engine and check that its npm package is on disk.
# We deliberately do not look at the actual node_modules tree of the *other*
# engine — users who only want playwright shouldn't be forced to install
# puppeteer, and vice versa.
case "$BROWSER_ENGINE" in
  puppeteer|playwright) ;;
  *)
    echo "html2pagx: unsupported --browser-engine '$BROWSER_ENGINE' (expected puppeteer or playwright)" >&2
    exit 2
    ;;
esac

if [[ ! -d "$SCRIPT_DIR/node_modules/$BROWSER_ENGINE" ]]; then
  echo "html2pagx: '$BROWSER_ENGINE' is not installed. Run:" >&2
  if [[ "$BROWSER_ENGINE" == "playwright" ]]; then
    echo "  cd $SCRIPT_DIR && npm install playwright" >&2
    echo "  npx --prefix $SCRIPT_DIR playwright install chromium" >&2
  else
    echo "  cd $SCRIPT_DIR && npm install" >&2
  fi
  exit 1
fi

if [[ "$BROWSER_ENGINE" == "puppeteer" ]]; then
  # Puppeteer ships with a pinned Chromium build cached in $PUPPETEER_CACHE_DIR
  # (defaults to ~/.cache/puppeteer). If it's missing — for example because npm
  # install ran inside a sandbox with a redirected cache — surface a clear
  # remediation rather than letting puppeteer-core throw a stack trace.
  PUPPETEER_CACHE_DIR_EFFECTIVE="${PUPPETEER_CACHE_DIR:-$HOME/.cache/puppeteer}"
  if [[ ! -d "$PUPPETEER_CACHE_DIR_EFFECTIVE/chrome" ]] \
      || [[ -z "$(ls "$PUPPETEER_CACHE_DIR_EFFECTIVE/chrome" 2>/dev/null)" ]]; then
    echo "html2pagx: puppeteer's bundled Chrome is missing from" >&2
    echo "          $PUPPETEER_CACHE_DIR_EFFECTIVE/chrome" >&2
    echo "Install it with:" >&2
    echo "  PUPPETEER_CACHE_DIR=\"$PUPPETEER_CACHE_DIR_EFFECTIVE\" \\" >&2
    echo "    npx --prefix $SCRIPT_DIR puppeteer browsers install chrome" >&2
    exit 1
  fi
fi

# Always forward the resolved engine so snapshot.js doesn't fall back to its
# own default (which would silently override what the user selected here).
SNAPSHOT_EXTRA_ARGS+=("--browser-engine" "$BROWSER_ENGINE")

if [[ "$DO_RESOLVE" -eq 1 || "$DO_RENDER" -eq 1 ]]; then
  if [[ ! -x "$PAGX_BIN" ]]; then
    echo "html2pagx: pagx binary not found or not executable: $PAGX_BIN" >&2
    echo "Pass --pagx-bin <path> or build it (cmake --build cmake-build-debug --target pagx)." >&2
    exit 1
  fi
fi

#--------------------------------------------------------------------------------------------------
# Step 1: snapshot
#--------------------------------------------------------------------------------------------------
# Total steps depends on which terminal step the user selected; pre-compute the
# count so the per-step prefix stays readable.
TOTAL_STEPS=2
[[ "$DO_RESOLVE" -eq 1 ]] && TOTAL_STEPS=3
[[ "$DO_RENDER" -eq 1 ]] && TOTAL_STEPS=4

echo "[1/$TOTAL_STEPS] snapshot  $INPUT_ABS"
run_step snapshot \
  node "$SCRIPT_DIR/snapshot.js" "$INPUT_ABS" -o "$SUBSET_HTML" \
  "${SNAPSHOT_EXTRA_ARGS[@]:+${SNAPSHOT_EXTRA_ARGS[@]}}"

#--------------------------------------------------------------------------------------------------
# Step 2: pagx import
#--------------------------------------------------------------------------------------------------
echo "[2/$TOTAL_STEPS] import    $SUBSET_HTML"
IMPORT_ARGS=(--input "$SUBSET_HTML" --output "$PAGX_FILE")
if [[ "$INFER_FLEX" -eq 1 ]]; then
  IMPORT_ARGS+=(--html-infer-flex)
fi
# `set -e` would abort on a non-zero `pagx import` exit, but we want to surface
# the failure with our own message; wrap the call to control the contract.
"$PAGX_BIN" import "${IMPORT_ARGS[@]}" 2>&1 \
  | grep -v "warning: html: position: absolute on text leaf" \
  || true

if [[ ! -f "$PAGX_FILE" ]]; then
  echo "html2pagx: pagx import did not produce $PAGX_FILE" >&2
  exit 1
fi

if [[ "$DO_RESOLVE" -ne 1 ]]; then
  echo "[done] wrote $PAGX_FILE (skipped resolve+render)"
  exit 0
fi

#--------------------------------------------------------------------------------------------------
# Step 3: pagx resolve
#--------------------------------------------------------------------------------------------------
echo "[3/$TOTAL_STEPS] resolve   $PAGX_FILE"
run_step "pagx resolve" "$PAGX_BIN" resolve "$PAGX_FILE"

if [[ "$DO_RENDER" -ne 1 ]]; then
  echo "[done] wrote $PAGX_FILE (skipped render)"
  exit 0
fi

#--------------------------------------------------------------------------------------------------
# Step 4: pagx render
#--------------------------------------------------------------------------------------------------
echo "[4/$TOTAL_STEPS] render    $PAGX_FILE  ->  $PNG_FILE (scale=$SCALE)"
run_step "pagx render" "$PAGX_BIN" render "$PAGX_FILE" --output "$PNG_FILE" --scale "$SCALE"

echo "[done] $PNG_FILE"
