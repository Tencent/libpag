<?xml version="1.0" encoding="UTF-8"?>
<!-- Text with non-Start textAnchor (position is default 0,0) but TextBox present -->
<pagx version="1.0" width="200" height="100">
  <Layer name="BadAnchorTextBox">
    <Text text="Hello" fontFamily="Arial" fontSize="24" textAnchor="center"/>
    <TextBox position="0,0" size="200,100"/>
    <Fill color="#333333"/>
  </Layer>
</pagx>
