<?xml version="1.0" encoding="UTF-8"?>
<!-- VIS-011: Consistent stroke widths (1.5px and 1.5px) -->
<pagx version="1.0" width="24" height="24">
  <Layer name="ConsistentStrokes">
    <Group>
      <Rectangle position="12,12" size="18,18"/>
      <Stroke color="currentColor" width="1.5"/>
    </Group>
    <Group>
      <Rectangle position="12,12" size="14,14"/>
      <Stroke color="currentColor" width="1.5"/>
    </Group>
  </Layer>
</pagx>
