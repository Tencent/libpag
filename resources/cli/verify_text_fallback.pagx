<pagx width="400" height="300">
  <!-- Text with system font should be measurable via font fallback. -->
  <Layer id="textLayer" width="400" height="300" layout="vertical" gap="10" padding="20">
    <Layer id="label">
      <Text fontFamily="Helvetica" fontSize="24" text="Hello World"/>
      <Fill color="#000000"/>
    </Layer>
    <Layer id="cjk">
      <Text fontFamily="PingFang SC" fontSize="24" text="你好世界"/>
      <Fill color="#333333"/>
    </Layer>
  </Layer>
</pagx>
