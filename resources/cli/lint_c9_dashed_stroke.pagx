  <Layer x="10" y="10" name="DashedStroke">
    <Rectangle position="0,0" size="15,15"/>
    <Stroke color="#000000" width="1" dashes="5,3"/>
    <Repeater copies="10" position="20,0"/>
  </Layer>
</pagx>
