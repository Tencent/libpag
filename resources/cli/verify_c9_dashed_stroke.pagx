  <Layer name="DashedStroke" left="10" top="10">
    <Rectangle left="-7.5" top="-7.5" width="15" height="15"/>
    <Stroke color="#000000" width="1" dashes="5,3"/>
    <Repeater copies="10" position="20,0"/>
  </Layer>
</pagx>
