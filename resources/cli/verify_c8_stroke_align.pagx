<!-- Test file for C8: Stroke with non-center alignment in Repeater -->
<pagx width="200" height="100">
  <Layer name="StrokeAlign" left="10" top="10">
    <Rectangle left="-10" top="-10" width="20" height="20"/>
    <Stroke color="#000000" width="2" align="inside"/>
    <Repeater copies="10" position="25,0"/>
  </Layer>
</pagx>
