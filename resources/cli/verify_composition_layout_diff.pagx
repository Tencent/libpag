<?xml version="1.0" encoding="UTF-8"?>
<!-- Test: Layers with different layout should NOT be detected as identical -->
<pagx width="400" height="200">
  <Layer name="container" width="400" height="200">
    <Layer width="100" height="100" layout="horizontal">
      <Layer width="100%" height="100%">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#FF0000"/>
      </Layer>
    </Layer>
    <Layer width="100" height="100" layout="vertical">
      <Layer width="100%" height="100%">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#FF0000"/>
      </Layer>
    </Layer>
  </Layer>
</pagx>
