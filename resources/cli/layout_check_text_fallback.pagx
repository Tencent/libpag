<pagx version="1.0" width="400" height="300">
  <!-- Text with system font should be measurable via font fallback. -->
  <Layer id="textLayer" width="400" height="300" layout="vertical" gap="10" padding="20">
    <Layer id="label">
      <Text text="Hello World" fontFamily="Helvetica" fontSize="24"/>
      <Fill color="#000000"/>
    </Layer>
    <Layer id="cjk">
      <Text text="你好世界" fontFamily="PingFang SC" fontSize="24"/>
      <Fill color="#333333"/>
    </Layer>
  </Layer>
</pagx>
