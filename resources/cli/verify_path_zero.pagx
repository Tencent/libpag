<pagx width="400" height="300">
  <Layer id="parent" width="400" height="300">
    <!-- Horizontal line: preferred height clamped to 1px. No zero-size warning. -->
    <Layer id="hline">
      <Path data="M0 0 L200 0"/>
      <Stroke color="#000000" width="2"/>
    </Layer>
    <!-- Vertical line: preferred width clamped to 1px. No zero-size warning. -->
    <Layer id="vline">
      <Path data="M0 0 L0 150"/>
      <Stroke color="#000000" width="2"/>
    </Layer>
  </Layer>
</pagx>
