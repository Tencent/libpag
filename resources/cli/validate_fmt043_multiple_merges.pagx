<?xml version="1.0" encoding="UTF-8"?>
<!-- FMT-043: Multiple MergePaths — first Fill+MergePath triggers, second is separate phase -->
<pagx version="1.0" width="24" height="24">
  <Layer name="MultipleMerges">
    <Rectangle size="20,20"/>
    <Fill color="#FF0000"/>
    <MergePath mode="union"/>
    <Ellipse size="10,10"/>
    <MergePath mode="difference"/>
    <Fill color="#0000FF"/>
  </Layer>
</pagx>
