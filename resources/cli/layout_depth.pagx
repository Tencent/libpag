<pagx width="400" height="300">
  <Layer id="root" width="400" height="300" layout="vertical">
    <Layer id="child1" height="100" layout="horizontal" gap="10" padding="10">
      <Layer id="grandchild1" flex="1">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#3B82F6"/>
      </Layer>
      <Layer id="grandchild2" flex="1">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#10B981"/>
      </Layer>
    </Layer>
    <Layer id="child2" flex="1">
      <Rectangle width="100%" height="100%"/>
      <Fill color="#EEE"/>
    </Layer>
  </Layer>
</pagx>
