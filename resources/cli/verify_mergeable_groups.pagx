<?xml version="1.0" encoding="UTF-8"?>
<!-- Test file for lint: adjacent Groups with same painters can be merged -->
<pagx width="200" height="200">
  <Layer name="container">
    <Group>
      <Rectangle width="50" height="50"/>
      <Fill color="#FF0000"/>
    </Group>
    <Group>
      <Rectangle width="80" height="40"/>
      <Fill color="#FF0000"/>
    </Group>
  </Layer>
</pagx>
