<?xml version="1.0" encoding="UTF-8"?>
<pagx version="1.0" width="200" height="200">
  <Layer id="exactClip">
    <Rectangle size="200,200"/>
  </Layer>
  <Layer id="bigClip">
    <Rectangle size="400,400"/>
  </Layer>
  <Layer name="exact" mask="@exactClip">
    <Rectangle left="50" top="50" size="100,100"/>
    <Fill color="#FF0000"/>
  </Layer>
  <Layer name="oversized" mask="@bigClip">
    <Ellipse left="60" top="60" size="80,80"/>
    <Fill color="#0000FF"/>
  </Layer>
</pagx>
