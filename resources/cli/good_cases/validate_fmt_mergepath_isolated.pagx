<?xml version="1.0" encoding="UTF-8"?>
<!-- compliant: Fill and MergePath isolated in separate Groups -->
<pagx version="1.0" width="24" height="24">
  <Layer name="GoodMergePath">
    <Group>
      <Rectangle size="20,20"/>
      <Fill color="#FF0000"/>
    </Group>
    <Group>
      <Ellipse center="12,12" size="16,16"/>
      <Rectangle size="10,10"/>
      <MergePath mode="difference"/>
      <Fill color="#0000FF"/>
    </Group>
  </Layer>
</pagx>
