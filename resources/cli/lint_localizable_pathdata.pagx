<!-- Test file for lint: PathData bounds not starting from origin -->
<pagx version="1.0" width="200" height="200">
  <Resources>
    <PathData id="offsetPath" data="M 50,50 L 150,50 L 150,100 Z"/>
  </Resources>
  <Layer name="shape">
    <Path data="@offsetPath"/>
    <Fill color="#FF0000"/>
  </Layer>
</pagx>
