<?xml version="1.0" encoding="UTF-8"?>
<!-- Test file for lint: redundant first-child Group that can be unwrapped.
     The Group is the only child of its parent, so unwrapping cannot let painters
     bleed onto subsequent siblings — the Group is genuinely redundant. -->
<pagx width="200" height="200">
  <Layer name="container">
    <Group>
      <Rectangle size="100,100"/>
      <Fill color="#FF0000"/>
    </Group>
  </Layer>
</pagx>
