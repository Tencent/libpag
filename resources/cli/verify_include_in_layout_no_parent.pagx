<?xml version="1.0" encoding="UTF-8"?>
<!-- Test: includeInLayout=false on child Layer without parent container layout -->
<pagx width="400" height="300">
  <Layer id="noLayout">
    <Layer id="excluded" includeInLayout="false" left="10" top="10">
      <Rectangle size="100,50"/>
      <Fill color="#FF0000"/>
    </Layer>
  </Layer>
</pagx>
