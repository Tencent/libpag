<?xml version="1.0" encoding="UTF-8"?>
<!-- Test file for lint: Path with rectangular verbs replaceable by Rectangle -->
<pagx version="1.0" width="200" height="200">
  <Resources>
    <PathData id="rectPath" data="M 0,0 L 100,0 L 100,50 L 0,50 Z"/>
  </Resources>
  <Layer name="shape">
    <Path data="@rectPath"/>
    <Fill color="#FF0000"/>
  </Layer>
</pagx>
