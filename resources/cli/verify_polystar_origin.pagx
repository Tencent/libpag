<pagx width="200" height="200">
  <!-- Polystar without explicit position should have layoutBounds starting at (0,0)
       via auto-position. Content-measured Layer should NOT report content-origin-offset. -->
  <Layer centerX="0" centerY="0">
    <Polystar innerRadius="18" outerRadius="40" pointCount="5" type="star"/>
    <Fill color="#F59E0B"/>
  </Layer>
</pagx>
