<?xml version="1.0" encoding="UTF-8"?>
<!-- Test: Two different PathData should NOT be detected as duplicates -->
<pagx width="200" height="200">
  <Resources>
    <PathData id="pd1" data="M 0,0 L 80,0 L 80,60 L 0,60 Z"/>
    <PathData id="pd2" data="M 0,0 L 100,0 L 100,80 L 0,80 Z"/>
  </Resources>
  <Layer name="shape1">
    <Path data="@pd1"/>
    <Fill color="#FF0000"/>
  </Layer>
  <Layer name="shape2">
    <Path data="@pd2"/>
    <Fill color="#0000FF"/>
  </Layer>
</pagx>
