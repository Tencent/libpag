<pagx width="400" height="300">
  <Layer width="400" height="300" layout="horizontal">
    <Layer flex="1" layout="vertical">
      <Layer height="50">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#EEE"/>
      </Layer>
      <Layer flex="1">
        <Rectangle width="100%" height="100%"/>
        <Fill color="#DDD"/>
      </Layer>
    </Layer>
  </Layer>
</pagx>
