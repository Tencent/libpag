<pagx width="400" height="300">
  <Layer width="400" height="300" layout="horizontal">
    <Layer flex="1" layout="vertical">
      <Layer height="50">
        <Rectangle left="0" right="0" top="0" bottom="0"/>
        <Fill color="#EEE"/>
      </Layer>
      <Layer flex="1">
        <Rectangle left="0" right="0" top="0" bottom="0"/>
        <Fill color="#DDD"/>
      </Layer>
    </Layer>
  </Layer>
</pagx>
