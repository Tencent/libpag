<?xml version="1.0" encoding="UTF-8"?>
<pagx version="1.0" width="200" height="200">
  <Layer name="gradient_fill">
    <Rectangle size="100,100"/>
    <Fill color="@grad1"/>
  </Layer>
  <Resources>
    <LinearGradient id="grad1" startPoint="0,0" endPoint="100,100">
      <ColorStop offset="0" color="#FF0000"/>
      <ColorStop offset="1" color="#0000FF"/>
    </LinearGradient>
  </Resources>
</pagx>
