<?xml version="1.0" encoding="UTF-8"?>
<!-- compliant: Text has no position or textAnchor when TextBox is present -->
<pagx version="1.0" width="200" height="100">
  <Layer name="GoodTextBox">
    <Text text="Hello" fontFamily="Arial" fontSize="24"/>
    <TextBox position="0,0" size="200,100"/>
    <Fill color="#333333"/>
  </Layer>
</pagx>
