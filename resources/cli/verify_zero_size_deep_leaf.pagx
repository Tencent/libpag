<pagx width="400" height="300">
  <!-- Container with explicit width="0" but has leaf content deep in the subtree.
       Zero size IS a real problem here and should be reported. -->
  <Layer width="400" height="300">
    <Layer width="0" height="100" layout="vertical">
      <Layer flex="1">
        <Rectangle width="80" height="40"/>
        <Fill color="#EF4444"/>
      </Layer>
    </Layer>
  </Layer>
</pagx>
