<!-- Test: nested container (correct pattern) should not trigger -->
<pagx width="400" height="200">
  <Layer width="400" height="200">
    <Rectangle left="0" right="0" top="0" bottom="0" roundness="8"/>
    <Fill color="#F8F9FA"/>
    <Layer left="0" right="0" top="0" bottom="0" layout="vertical" padding="16">
      <Layer height="40">
        <Rectangle left="0" right="0" top="0" bottom="0"/>
        <Fill color="#3B82F6"/>
      </Layer>
    </Layer>
  </Layer>
</pagx>
