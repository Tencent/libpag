<?xml version="1.0" encoding="UTF-8"?>
<!-- Test: Groups with Fill+Stroke identical should be mergeable -->
<pagx version="1.0" width="200" height="200">
  <Layer name="container">
    <Group>
      <Rectangle size="50,50"/>
      <Fill color="#FF0000"/>
      <Stroke color="#000000" width="2"/>
    </Group>
    <Group>
      <Ellipse size="80,40"/>
      <Fill color="#FF0000"/>
      <Stroke color="#000000" width="2"/>
    </Group>
  </Layer>
</pagx>
