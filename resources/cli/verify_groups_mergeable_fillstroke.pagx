<?xml version="1.0" encoding="UTF-8"?>
<!-- Test: Groups with Fill+Stroke identical should be mergeable -->
<pagx width="200" height="200">
  <Layer name="container">
    <Group>
      <Rectangle width="50" height="50"/>
      <Fill color="#FF0000"/>
      <Stroke color="#000000" width="2"/>
    </Group>
    <Group>
      <Ellipse width="80" height="40"/>
      <Fill color="#FF0000"/>
      <Stroke color="#000000" width="2"/>
    </Group>
  </Layer>
</pagx>
