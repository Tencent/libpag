<?xml version="1.0" encoding="UTF-8"?>
<!-- Odd stroke width (3px) with layer position at strict half-pixel (0.5, 0.5) -->
<pagx version="1.0" width="24" height="24">
  <Layer name="OddStrokeAligned" x="0.5" y="0.5">
    <Rectangle position="12,12" size="18,18"/>
    <Stroke color="currentColor" width="3"/>
  </Layer>
</pagx>
