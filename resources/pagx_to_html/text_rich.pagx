<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: Rich text (multiple Text elements in Group + independent Fill colors + shared TextBox) -->
<pagx version="1.0" width="360" height="260">
  <!-- Background -->
  <Layer>
    <Rectangle position="180,130" size="360,260"/>
    <Fill color="#F1F5F9"/>
  </Layer>

  <!-- Title -->
  <Layer>
    <Text text="Rich Text" fontFamily="Arial" fontStyle="Bold" fontSize="16" position="180,34" textAnchor="center"/>
    <Fill color="#1E293B"/>
  </Layer>
  <Layer>
    <Text text="Multi-color spans with shared TextBox" fontFamily="Arial" fontSize="10" position="180,50" textAnchor="center"/>
    <Fill color="#94A3B8"/>
  </Layer>

  <!-- Card -->
  <Layer>
    <Rectangle position="180,150" size="300,155" roundness="16"/>
    <Fill color="#FFFFFF"/>
    <DropShadowStyle offsetX="0" offsetY="4" blurX="16" blurY="16" color="#1E293B15"/>
  </Layer>

  <Layer>
    <!-- First text span: red bold -->
    <Group>
      <Text text="Hello " fontFamily="Arial" fontStyle="Bold" fontSize="24" position="10,10"/>
      <Fill color="#EF4444"/>
    </Group>
    <!-- Second text span: blue italic -->
    <Group>
      <Text text="Beautiful " fontFamily="Arial" fontStyle="Italic" fontSize="24" position="10,10"/>
      <Fill color="#3B82F6"/>
    </Group>
    <!-- Third text span: green bold -->
    <Group>
      <Text text="World!" fontFamily="Arial" fontStyle="Bold" fontSize="24" position="10,10"/>
      <Fill color="#10B981"/>
    </Group>
    <!-- Fourth text span: purple with stroke -->
    <Group>
      <Text text=" Mixed " fontFamily="Arial" fontStyle="Bold" fontSize="20" position="10,10"/>
      <Fill color="#8B5CF6"/>
      <Stroke color="#6D28D9" width="0.5"/>
    </Group>
    <!-- Fifth text span: orange -->
    <Group>
      <Text text="Styles" fontFamily="Arial" fontStyle="Bold Italic" fontSize="20" position="10,10"/>
      <Fill color="#F59E0B"/>
    </Group>
    <!-- Shared text box for layout -->
    <TextBox position="40,88" size="280,120" textAlign="center" paragraphAlign="middle"/>
  </Layer>
</pagx>
