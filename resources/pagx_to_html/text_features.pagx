<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: Text features — letterSpacing, fauxBold, fauxItalic, CDATA multiline, TextBox overflow="visible" -->
<pagx version="1.0" width="420" height="320">
  <Resources>
    <LinearGradient id="headerGrad" startPoint="10,10" endPoint="410,10">
      <ColorStop offset="0" color="#6366F1"/>
      <ColorStop offset="1" color="#EC4899"/>
    </LinearGradient>
  </Resources>

  <!-- Header label -->
  <Layer>
    <Text text="Typography Specimen" fontFamily="Arial" fontStyle="Bold" fontSize="18" position="210,38" textAnchor="center"/>
    <Fill color="@headerGrad"/>
  </Layer>

  <!-- Divider -->
  <Layer>
    <Path data="M 20,40 L 380,40"/>
    <Stroke color="#E2E8F0" width="1"/>
  </Layer>

  <!-- 1. letterSpacing="8" -->
  <Layer>
    <Text text="letterSpacing" fontFamily="Arial" fontSize="10" position="30,68"/>
    <Fill color="#94A3B8"/>
  </Layer>
  <Layer>
    <Text text="SPACED OUT" fontFamily="Arial" fontStyle="Bold" fontSize="22" position="30,94" letterSpacing="8"/>
    <Fill color="#3B82F6"/>
  </Layer>

  <!-- 2. fauxBold="true" -->
  <Layer>
    <Text text="fauxBold" fontFamily="Arial" fontSize="10" position="30,118"/>
    <Fill color="#94A3B8"/>
  </Layer>
  <Layer>
    <Text text="Faux Bold Text" fontFamily="Arial" fontSize="20" position="30,142" fauxBold="true"/>
    <Fill color="#8B5CF6"/>
  </Layer>

  <!-- 3. fauxItalic="true" -->
  <Layer>
    <Text text="fauxItalic" fontFamily="Arial" fontSize="10" position="230,118"/>
    <Fill color="#94A3B8"/>
  </Layer>
  <Layer>
    <Text text="Faux Italic Text" fontFamily="Arial" fontSize="20" position="230,142" fauxItalic="true"/>
    <Fill color="#EC4899"/>
  </Layer>

  <!-- 4. CDATA multiline content -->
  <Layer>
    <Text text="CDATA multiline" fontFamily="Arial" fontSize="10" position="30,168"/>
    <Fill color="#94A3B8"/>
  </Layer>
  <Layer>
    <Text fontFamily="Arial" fontSize="16" position="30,188">
<![CDATA[Line 1
Line 2
Line 3]]>
    </Text>
    <Fill color="#10B981"/>
  </Layer>

  <!-- 5. TextBox with overflow="visible" — text extends beyond box boundary -->
  <Layer>
    <Text text="overflow=visible" fontFamily="Arial" fontSize="10" position="230,168"/>
    <Fill color="#94A3B8"/>
  </Layer>
  <!-- Visible box boundary (dashed) -->
  <Layer>
    <Rectangle position="310,230" size="140,50"/>
    <Stroke color="#F59E0B" width="1" dashes="4,3"/>
  </Layer>
  <!-- Text overflows the small box -->
  <Layer>
    <Text text="This text overflows the small box and remains visible beyond its boundaries." fontFamily="Arial" fontSize="14" position="10,10"/>
    <TextBox position="240,205" size="140,50" overflow="visible" wordWrap="true"/>
    <Fill color="#F59E0B"/>
  </Layer>
</pagx>
