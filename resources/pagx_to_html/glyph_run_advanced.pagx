<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: GlyphRun advanced — positions, anchors, skews, combined transforms, bitmap glyphs -->
<pagx version="1.0" width="420" height="430">
  <Resources>
    <!-- Vector font with P, A, G, X glyphs -->
    <Font id="vecFont" unitsPerEm="1000">
      <!-- P: vertical bar + upper bowl -->
      <Glyph id="gP" advance="580" path="M 80,0 L 80,-800 L 350,-800 C 520,-800 520,-400 350,-400 L 180,-400 L 180,0 Z M 180,-500 L 330,-500 C 400,-500 420,-550 420,-600 C 420,-650 400,-700 330,-700 L 180,-700 Z"/>
      <!-- A: triangle with crossbar -->
      <Glyph id="gA" advance="650" path="M 0,0 L 220,-800 L 430,-800 L 650,0 L 530,0 L 470,-200 L 180,-200 L 120,0 Z M 210,-310 L 440,-310 L 325,-720 Z"/>
      <!-- G: C-shape with horizontal midline arm -->
      <Glyph id="gG" advance="640" path="M 530,-680 L 460,-590 C 410,-650 340,-700 260,-700 C 140,-700 90,-580 90,-400 C 90,-220 140,-100 260,-100 C 310,-100 350,-110 390,-140 L 390,-340 L 300,-340 L 300,-440 L 530,-440 L 530,-20 C 470,10 370,30 270,30 C 80,30 0,-130 0,-400 C 0,-670 80,-830 270,-830 C 380,-830 470,-780 530,-680 Z"/>
      <!-- X: two diagonal strokes -->
      <Glyph id="gX" advance="600" path="M 0,0 L 200,-400 L 0,-800 L 130,-800 L 300,-460 L 470,-800 L 600,-800 L 400,-400 L 600,0 L 470,0 L 300,-340 L 130,0 Z"/>
    </Font>

    <!-- Bitmap font for image glyph testing -->
    <Font id="bmpFont" unitsPerEm="100">
      <!-- Star glyph with offset -->
      <Glyph id="gStar" advance="50" image="data:image/png;base64," offset="0,-4"/>
      <!-- Heart glyph without offset -->
      <Glyph id="gHeart" advance="50" image="data:image/png;base64,"/>
    </Font>
  </Resources>

  <!-- Background -->
  <Layer left="0" right="0" top="0" bottom="0">
    <Rectangle left="0" right="0" top="0" bottom="0"/>
    <Fill color="#F8FAFC"/>
  </Layer>

  <!-- Main container -->
  <Layer left="0" right="0" top="0" bottom="0" layout="vertical" padding="16,24,16,24" gap="6" alignment="stretch">
    <!-- Title -->
    <Layer layout="vertical" gap="2" alignment="center">
      <Layer height="20">
        <Text text="GlyphRun Advanced" fontFamily="Arial" fontStyle="Bold" fontSize="16" centerX="0" textAnchor="center"/>
        <Fill color="#1E293B"/>
      </Layer>
      <Layer height="12">
        <Text text="positions, anchors, skews, combined, bitmap" fontFamily="Arial" fontSize="9" centerX="0" textAnchor="center"/>
        <Fill color="#94A3B8"/>
      </Layer>
    </Layer>

    <!-- Card -->
    <Layer flex="1">
      <Rectangle left="0" right="0" top="0" bottom="0" roundness="12"/>
      <Fill color="#FFFFFF"/>
      <DropShadowStyle offsetX="0" offsetY="2" blurX="12" blurY="12" color="#1E293B12"/>

      <Layer left="0" right="0" top="0" bottom="0" layout="vertical" padding="14" gap="8" alignment="stretch">

        <!-- Row 1: positions -->
        <Layer layout="vertical" gap="3">
          <Layer height="12">
            <Text text="positions" fontFamily="Arial" fontSize="10"/>
            <Fill color="#94A3B8"/>
          </Layer>
          <Layer height="44">
            <Text>
              <GlyphRun font="@vecFont" fontSize="36" glyphs="1,2,3,4" x="8" y="40" xOffsets="0,29,60,91" positions="0,0;3,-6;-2,4;5,-3"/>
            </Text>
            <Fill color="#3B82F6"/>
            <Stroke color="#1D4ED8" width="1"/>
          </Layer>
        </Layer>

        <!-- Row 2: anchors + rotations -->
        <Layer layout="horizontal" gap="16" alignment="stretch">
          <Layer flex="1" layout="vertical" gap="3">
            <Layer height="12">
              <Text text="anchors + rotations" fontFamily="Arial" fontSize="10"/>
              <Fill color="#94A3B8"/>
            </Layer>
            <Layer height="44">
              <Text>
                <GlyphRun font="@vecFont" fontSize="28" glyphs="1,2,3,4" x="4" y="36" xOffsets="0,22,46,70" anchors="0,0;4,-10;-3,6;0,-8" rotations="8,-6,10,-5"/>
              </Text>
              <Fill color="#10B981"/>
            </Layer>
          </Layer>

          <!-- Row 2 right: skews -->
          <Layer flex="1" layout="vertical" gap="3">
            <Layer height="12">
              <Text text="skews" fontFamily="Arial" fontSize="10"/>
              <Fill color="#94A3B8"/>
            </Layer>
            <Layer height="44">
              <Text>
                <GlyphRun font="@vecFont" fontSize="28" glyphs="1,2,3,4" x="4" y="36" xOffsets="0,22,46,70" skews="12,-8,15,-10"/>
              </Text>
              <Fill color="#8B5CF6"/>
            </Layer>
          </Layer>
        </Layer>

        <!-- Row 3: all combined -->
        <Layer layout="vertical" gap="3">
          <Layer height="12">
            <Text text="combined: positions + anchors + skews + scales + rotations" fontFamily="Arial" fontSize="10"/>
            <Fill color="#94A3B8"/>
          </Layer>
          <Layer height="48">
            <Text>
              <GlyphRun font="@vecFont" fontSize="32" glyphs="1,2,3,4" x="8" y="42"
                         xOffsets="0,26,53,81"
                         positions="0,0;4,-4;-3,5;6,-2"
                         anchors="0,-8;3,0;-4,4;0,-6"
                         skews="8,-4,10,-6"
                         scales="1.1,1;0.9,1.1;1,0.9;1.05,1.05"
                         rotations="5,-7,9,-4"/>
            </Text>
            <Fill color="#EC4899"/>
          </Layer>
        </Layer>

        <!-- Row 4: bitmap glyphs -->
        <Layer layout="vertical" gap="3">
          <Layer height="12">
            <Text text="bitmap glyphs (star with offset, heart without)" fontFamily="Arial" fontSize="10"/>
            <Fill color="#94A3B8"/>
          </Layer>
          <Layer height="70">
            <Text>
              <GlyphRun font="@bmpFont" fontSize="100" glyphs="1,2,1" x="30" y="30" xOffsets="0,70,140"/>
            </Text>
            <Fill color="#F59E0B"/>
          </Layer>
        </Layer>

      </Layer>
    </Layer>
  </Layer>
</pagx>
