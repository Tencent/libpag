<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: TextPath — text along curves with various configurations:
     simple arc, perpendicular=false, multiple paths, firstMargin/lastMargin -->
<pagx version="1.0" width="420" height="280">
  <Resources>
    <PathData id="arcPath" data="M 30,150 C 100,20 300,20 370,150"/>
    <PathData id="straightLine" data="M 30,180 L 370,180"/>
  </Resources>

  <!-- Background -->
  <Layer>
    <Rectangle position="210,140" size="420,280"/>
    <Fill color="#F1F5F9"/>
  </Layer>

  <!-- Title -->
  <Layer>
    <Text text="Text Path" fontFamily="Arial" fontStyle="Bold" fontSize="16" position="210,34" textAnchor="center"/>
    <Fill color="#1E293B"/>
  </Layer>
  <Layer>
    <Text text="Text along curves, perpendicular modes, and margins" fontFamily="Arial" fontSize="10" position="210,50" textAnchor="center"/>
    <Fill color="#94A3B8"/>
  </Layer>

  <!-- Card -->
  <Layer>
    <Rectangle position="210,162" size="360,175" roundness="16"/>
    <Fill color="#FFFFFF"/>
    <DropShadowStyle offsetX="0" offsetY="4" blurX="16" blurY="16" color="#1E293B15"/>
  </Layer>

  <!-- Text along bezier curve (perpendicular=true) -->
  <Layer>
    <Text text="Text Along a Path" fontFamily="Arial" fontStyle="Bold" fontSize="24" position="10,10"/>
    <TextPath path="@arcPath" perpendicular="true" firstMargin="10"/>
    <Fill color="#3B82F6"/>
  </Layer>

  <!-- Same path, perpendicular=false: glyphs stay upright -->
  <Layer>
    <Text text="Upright Glyphs" fontFamily="Arial" fontSize="16" position="10,10"/>
    <TextPath path="@arcPath" perpendicular="false" firstMargin="80" lastMargin="80"/>
    <Fill color="#EF444480"/>
  </Layer>

  <!-- Text on straight line with margins -->
  <Layer>
    <Text text="Straight Path" fontFamily="Arial" fontSize="14" position="10,10"/>
    <TextPath path="@straightLine" firstMargin="20" lastMargin="20"/>
    <Fill color="#10B981"/>
  </Layer>

  <!-- S-curve path defined inline -->
  <Layer>
    <Text text="S-CURVE" fontFamily="Arial" fontStyle="Bold" fontSize="18" position="10,10"/>
    <TextPath path="M 30,100 C 100,40 150,160 220,100 C 290,40 340,160 370,100"/>
    <Fill color="#8B5CF6"/>
  </Layer>
</pagx>
