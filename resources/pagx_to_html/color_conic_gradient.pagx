<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: ConicGradient → CSS conic-gradient; angle convention (PAGX 0°=right, CSS 0°=up → +90°) -->
<pagx version="1.0" width="380" height="280">
  <!-- Background -->
  <Layer>
    <Rectangle position="190,140" size="380,280"/>
    <Fill color="#F1F5F9"/>
  </Layer>

  <!-- Title -->
  <Layer>
    <Text text="Conic Gradient" fontFamily="Arial" fontStyle="Bold" fontSize="16" position="190,34" textAnchor="center"/>
    <Fill color="#1E293B"/>
  </Layer>
  <Layer>
    <Text text="Full 360-degree and partial angle range" fontFamily="Arial" fontSize="10" position="190,50" textAnchor="center"/>
    <Fill color="#94A3B8"/>
  </Layer>

  <!-- Card -->
  <Layer>
    <Rectangle position="190,162" size="320,170" roundness="16"/>
    <Fill color="#FFFFFF"/>
    <DropShadowStyle offsetX="0" offsetY="4" blurX="16" blurY="16" color="#1E293B15"/>
  </Layer>

  <!-- Full 360° conic -->
  <Layer>
    <Ellipse position="115,158" size="120,120"/>
    <Fill>
      <ConicGradient center="70,70" startAngle="0" endAngle="360">
        <ColorStop offset="0" color="#EF4444"/>
        <ColorStop offset="0.33" color="#10B981"/>
        <ColorStop offset="0.66" color="#3B82F6"/>
        <ColorStop offset="1" color="#EF4444"/>
      </ConicGradient>
    </Fill>
  </Layer>
  <Layer>
    <Text text="Full 360" fontFamily="Arial" fontSize="9" position="115,230" textAnchor="center"/>
    <Fill color="#64748B"/>
  </Layer>

  <!-- Partial angle range: startAngle=45 endAngle=270 -->
  <Layer>
    <Ellipse position="275,158" size="120,120"/>
    <Fill>
      <ConicGradient center="70,70" startAngle="45" endAngle="270">
        <ColorStop offset="0" color="#F59E0B"/>
        <ColorStop offset="1" color="#8B5CF6"/>
      </ConicGradient>
    </Fill>
  </Layer>
  <Layer>
    <Text text="Partial (45-270)" fontFamily="Arial" fontSize="9" position="275,230" textAnchor="center"/>
    <Fill color="#64748B"/>
  </Layer>
</pagx>
