<!-- Tests: Layer alpha → opacity -->
<pagx version="1.0" width="200" height="200">
  <Layer alpha="0.3">
    <Rectangle position="80,80" size="120,120"/>
    <Fill color="#EF4444"/>
  </Layer>
  <Layer alpha="0.7">
    <Rectangle position="120,120" size="120,120"/>
    <Fill color="#3B82F6"/>
  </Layer>
</pagx>
