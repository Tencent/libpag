<?xml version="1.0" encoding="UTF-8"?>
<!-- Tests: Layer visible attribute → display:none -->
<pagx version="1.0" width="200" height="200">
  <Layer>
    <Rectangle center="100,100" size="160,160"/>
    <Fill color="#3B82F6"/>
  </Layer>
  <Layer visible="false">
    <Rectangle center="100,100" size="120,120"/>
    <Fill color="#EF4444"/>
  </Layer>
</pagx>
