<?xml version="1.0" encoding="UTF-8"?>
<pagx width="400" height="400">
  <Layer>
    <Rectangle left="50" top="100" roundness="32" size="300,200"/>
    <Fill>
      <LinearGradient endPoint="300,200" startPoint="0,0">
        <ColorStop color="#F59E0B" offset="0"/>
        <ColorStop color="#F43F5E" offset="1"/>
      </LinearGradient>
    </Fill>
    <Fill color="#8B5CF640"/>
    <DropShadowStyle blurX="40" blurY="40" color="#F43F5E50" offsetY="12"/>
  </Layer>
</pagx>
