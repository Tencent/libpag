<?xml version="1.0" encoding="UTF-8"?>
<!-- Demonstrates Group isolation: alpha applied to group, not individual shapes -->
<pagx width="400" height="400">
  <Layer>
    <Group alpha="0.7">
      <Rectangle left="40" top="100" size="200,200" roundness="24"/>
      <Fill color="#F43F5E"/>
    </Group>
    <Ellipse left="160" top="100" size="200,200"/>
    <Fill color="#06B6D4"/>
  </Layer>
</pagx>
